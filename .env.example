# ========================================
# Volina Dashboard — Environment Variables
# ========================================
# Copy to .env.local for local development.
# In Vercel, add these via Project Settings → Environment Variables.

# ── NextAuth ──────────────────────────────
NEXTAUTH_URL=https://dashboard.volina.ai
NEXTAUTH_SECRET=               # openssl rand -base64 32

# ── Supabase ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://ydgsarbkvtyjevyzyuzq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=     # server-side only

# ── Vapi ──────────────────────────────────
VAPI_PRIVATE_KEY=
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
NEXT_PUBLIC_VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=

# ── Google OAuth / Calendar ───────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OpenAI (call evaluation) ──────────────
OPENAI_API_KEY=

# ── Cron Secret ───────────────────────────
CRON_SECRET=                   # used by /api/cron/* and /api/admin/setup-tenant
